# Copy to `.env` locally. Set these in your host (e.g. Vercel) for production.

# Public site URL (metadata, OG, sitemap, emails) — no trailing slash
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Supabase (browser + server data reads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: admin scripts / bypass RLS (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional
NEXT_PUBLIC_GA_ID=
OPENWEATHER_API_KEY=
