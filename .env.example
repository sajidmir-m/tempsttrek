# Copy to `.env` locally. Set these in your host (e.g. Vercel) for production.

# Public site URL (metadata, OG, sitemap, robots, emails) — no trailing slash.
# Use https://www.tempesttreks.in in production (Vercel/host env). Do NOT set localhost here on deploy.
NEXT_PUBLIC_SITE_URL=https://www.tempesttreks.in

# Supabase (browser + server data reads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: admin scripts / bypass RLS (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional
NEXT_PUBLIC_GA_ID=
OPENWEATHER_API_KEY=
RESEND_API_KEY=
RESEND_FROM=
